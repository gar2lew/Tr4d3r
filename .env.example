# ===================================================================
# AI Hummingbot Brain — environment template
# Copy this to `.env` and fill in your OpenRouter key.
# NEVER commit your real .env file.
# ===================================================================

# --- OpenRouter (the AI brain) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional headers that OpenRouter recommends:
OPENROUTER_REFERER=https://localhost
APP_NAME=AI Hummingbot Brain

# --- AI committee models (cheap defaults) ---
# Change these any time; values are stored in settings.json after first save.
OPENROUTER_MODEL_COMMANDER=openai/gpt-4o-mini
OPENROUTER_MODEL_SCOUT=google/gemini-2.5-flash-lite
OPENROUTER_MODEL_RISK=deepseek/deepseek-chat
OPENROUTER_MODEL_SKEPTIC=openai/gpt-4o-mini

# --- Paper engine defaults ---
STARTING_BALANCE_USDT=100
TIMEFRAME=15m
BIAS_TIMEFRAME=1h
PRICE_REFRESH_SECONDS=1
# V7 default: 30s. The scanner now sweeps up to MAX_SCAN_SYMBOLS markets per
# scan; 30s gives OKX rate-limit cooldowns room to breathe.
SCAN_INTERVAL_SECONDS=30
AI_TIMEOUT_SECONDS=7
AI_MAX_TOKENS=140
RIDE_WINNERS_ENABLED=true
ACTIVE_STRATEGY=commander_blend

# --- Execution mode (V5 training gate) ---
# paper    = local paper account only (default)
# okx_demo = OKX simulated trading API after Hermes training gate passes
# okx_live = real OKX spot orders only after gate + explicit env acks
EXECUTION_MODE=paper

# Training gate — these are MINIMUMS the Hermes journal must meet before
# okx_demo or okx_live can pass /api/live/readiness. Make these stricter,
# not looser, on first runs.
LIVE_MIN_CLOSED_TRADES=30
LIVE_MIN_WIN_RATE=0.55
LIVE_MIN_TOTAL_PNL_USDT=0
LIVE_MIN_DATA_QUALITY_SCORE=90

# Real-money order size cap. The server clamps this between 1 and 50 USDT.
# Start tiny. Increase only after a clean demo run.
LIVE_MAX_ORDER_USDT=10

# --- OKX private API for demo/live readiness checks ---
# Create keys with Trade + Read only. Withdrawals OFF.
# The build is spot-only. Perps/leverage on OKX are NOT wired here.
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_DEMO=true

# --- V6.2: OKX private REST host ---
# Default: https://us.okx.com (matches accounts created via the US /
# regional landing pages).
#
# WHY THIS EXISTS: a perfectly valid OKX API key can still return
#   HTTP 401  {"code":"50119","msg":"API key doesn't exist"}
# when hit against the wrong host. The user verified that the same
# signed GET /api/v5/account/balance returns:
#   https://www.okx.com  → 401 50119 "API key doesn't exist"
#   https://us.okx.com   → 200 code:0  ✅
#   https://app.okx.com  → 200 code:0  ✅
#
# If your account was created on the global / EU host you may instead
# need OKX_BASE_URL=https://www.okx.com or https://eea.okx.com. The UI
# shows which host was actually used in the OKX account / diagnostic
# panels.
OKX_BASE_URL=https://us.okx.com

# Optional: separate host for unsigned market-data calls
# (/api/v5/market/tickers, /api/v5/market/candles). Leave blank to
# inherit OKX_BASE_URL; the legacy default if neither is set is
# https://www.okx.com (public endpoints work on every host).
OKX_PUBLIC_BASE_URL=

# Real-money LIVE requires ALL of the following AND a passing training gate:
#   EXECUTION_MODE=okx_live
#   OKX_DEMO=false
#   LIVE_TRADING_ENABLED=true
#   LIVE_TRADING_ACK=I_ACCEPT_REAL_MONEY_RISK
#   LIVE_DEMO_COMPLETED_ACK=I_RAN_OKX_DEMO_FIRST     # proof you tested demo
LIVE_TRADING_ACK=
LIVE_DEMO_COMPLETED_ACK=

# --- Leverage simulator (paper / demo only) ---
# This is a SIMULATION. Real OKX leverage / perps are NOT enabled in this
# build. The simulator amplifies paper notional, fees, P/L, and adds a
# liquidation check so you can stress-test before requesting a perps adapter.
LEVERAGE_ENABLED=false
LEVERAGE_MULTIPLIER=1.0
LEVERAGE_MAX_MULTIPLIER=3.0
LEVERAGE_LIQUIDATION_BUFFER_PCT=80
LEVERAGE_MAX_DAILY_LOSS_PCT=3.0
LEVERAGE_EXTRA_MIN_CLOSED_TRADES=60

SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,DOGE/USDT,AVAX/USDT,LINK/USDT,ADA/USDT

# --- Server ---
HTTP_HOST=0.0.0.0
HTTP_PORT=8787

# --- LIVE TRADING UNLOCK ---
# Required (with LIVE_TRADING_ACK and LIVE_DEMO_COMPLETED_ACK) for okx_live to
# pass the gate. Even when this is true, /api/live/readiness still verifies the
# Hermes training journal AND OKX credentials before reporting can_execute.
LIVE_TRADING_ENABLED=false

# ===================================================================
# V5.1 — Active paper training / auto-strategy / dynamic discovery
# ===================================================================
# These options ONLY affect paper mode. They never relax the demo/live
# training gate, never lower LIVE_MAX_ORDER_USDT, and never enable real
# trading. They exist so the bot can actually take more paper trades on
# real OKX market data and learn faster.

# Take paper trades below the strict confidence threshold (PAPER ONLY).
# Each exploratory entry is journaled with reason
# "[EXPLORATORY PAPER TRAINING] ...".
ACTIVE_PAPER_TRAINING=true
PAPER_TRAINING_MIN_SCORE=0.42
PAPER_TRAINING_ALLOW_EXPLORATION=true
PAPER_TRAINING_SIZE_PCT=50         # % of normal size used for training entries
PAPER_TRAINING_MAX_DAILY_TRADES=12

# Auto-pick the best strategy per scan using indicator scores PLUS a
# Hermes win-rate bonus (capped ±0.05). When false, the bot follows the
# manually selected ACTIVE_STRATEGY only.
AUTO_STRATEGY_SELECTION=true

# Dynamically discover liquid OKX USDT spot symbols and scan them too.
# Uses the public /api/v5/market/tickers feed (15-min cache). Symbols
# must pass a 24h-volume floor and a tight spread filter before being
# included. Discovery only affects paper scanning.
DYNAMIC_SYMBOL_DISCOVERY=true
# V7 default raised back to 20 (from V5.2's 10) so the scanner sees the top
# ~20 liquid USDT spot pairs alongside the 8 core symbols. The MAX_SCAN_SYMBOLS
# ceiling below caps the combined universe so OKX rate limits are still safe.
MAX_DYNAMIC_SYMBOLS=20

# V7 — hard ceiling for (core + discovered) symbols actually scanned each
# cycle. Server clamps 8..80. Default 25 = 8 core + ~17 discovered.
MAX_SCAN_SYMBOLS=25

# V7 — optional market-intel provider. "none" means OKX-public-only, which
# is sufficient for all fills. "coingecko" is a placeholder for future
# enrichment (no key needed but not yet wired). Anything else falls back
# to "none" so offline / no-key use never breaks.
MARKET_INTEL_PROVIDER=none
DYNAMIC_MIN_QUOTE_VOLUME_USDT=5000000   # 5M USDT 24h quote-vol floor

# ===================================================================
# V9 — OKX NATIVE EXCHANGE TP/SL (opt-in; bot-managed exits stay armed)
# ===================================================================
# When LIVE_NATIVE_PROTECTION_ENABLED=true the tiny live tester places
# exchange-side algo sells (OCO or two conditional orders) on OKX after
# a successful spot BUY fills. Those trigger prices ARE visible in the
# OKX algo-orders panel and will fire even if this bot process stops.
#
# The bot-managed price watcher REMAINS armed in parallel — native
# protection is an additional layer, NOT a replacement. If the native
# placement is rejected (e.g. invalid trigger, instrument disabled,
# permission missing) the UI shows "NATIVE FAILED – BOT FALLBACK" and
# the bot-managed exits handle the position normally.
#
# Mode:
#   oco         — (recommended) one OCO order with TP + SL attached.
#                 Counts as ONE algo against OKX's per-instrument cap.
#   conditional — two separate conditional orders (TP + SL). Counts as
#                 TWO algos. Use only if your account/region rejects OCO.
#   off         — same as ENABLED=false. No native orders are sent.
#
# Safety:
#   - Bot-managed protection runs in parallel and is the source of
#     truth for trailing stops.
#   - On any bot-managed close, kill switch, or manual cancel the
#     attached native algos are cancelled FIRST so OKX cannot double-sell.
#   - LIVE_NATIVE_PROTECTION_DRY_RUN=true short-circuits the OKX call
#     and records a journal entry only — useful for end-to-end UI
#     verification without spending an exchange algo slot.
#
# This project remains OKX SPOT LONG only. No shorts, perps, margin,
# borrow, leverage, withdrawals, or transfers are placed by this build.
LIVE_NATIVE_PROTECTION_ENABLED=false
LIVE_NATIVE_PROTECTION_MODE=oco
LIVE_NATIVE_PROTECTION_DRY_RUN=false
# V9 — if true, on bot startup the live tester walks every open position
# and (a) refreshes the OKX-side inventory snapshot, (b) re-attaches native
# OCO/conditional sells when LIVE_NATIVE_PROTECTION_ENABLED=true and a
# position is currently unprotected. This NEVER opens new positions and
# NEVER cancels positions; it only attaches missing exits.
LIVE_NATIVE_PROTECTION_RECONCILE_ON_STARTUP=false

# ===================================================================
# V9 — Unattended live-test mode (5-day envelope)
# ===================================================================
#
# Intended for a *risk-reduced tiny live test* you can leave running for
# up to 5 days. This is NOT safe automation — it is a tight envelope that
# auto-disables on the timer or on critical failures.
#
# Before flipping LIVE_UNATTENDED_MODE to true:
#   - LIVE_NATIVE_PROTECTION_ENABLED must be true and verified working on
#     a manual paper-style attempt (the readiness panel must show PASS).
#   - All tiny caps below should be set to the recommended values.
#   - The Unattended Readiness panel banner must read
#     "SAFE-ish for unattended tiny test" — if it reads
#     "DO NOT LEAVE UNATTENDED", do NOT walk away.
#
# Behaviour when LIVE_UNATTENDED_MODE=true:
#   - On first heartbeat after the flag is set, the tester records
#     LIVE_UNATTENDED_STARTED_AT (unix seconds).
#   - After LIVE_UNATTENDED_MAX_HOURS the kill switch latches automatically
#     and the reason is "unattended timer expired after N.Nh".
#   - gate_check refuses NEW entries while: readiness is FAIL, the timer
#     has expired, or there have been ≥5 consecutive OKX API errors.
#   - Existing open positions are NOT closed automatically. The bot
#     continues to watch them; native TP/SL on OKX continues to protect
#     them on the exchange side even if the bot exits.
LIVE_UNATTENDED_MODE=false
LIVE_UNATTENDED_MAX_HOURS=120
# Leave LIVE_UNATTENDED_STARTED_AT at 0 — the bot will set this itself
# (and persist it to data/live_state.json) the first time the heartbeat
# fires with LIVE_UNATTENDED_MODE=true.
LIVE_UNATTENDED_STARTED_AT=0
# When true, the unattended gate also refuses new entries on the
# environment failure modes above (API error burst, stale market data,
# stale heartbeat). Leave true for the documented 5-day envelope.
LIVE_UNATTENDED_STOP_NEW_ON_FAILURE=true

# V5.2 — bases excluded from dynamic discovery on top of the built-in
# stable / wrapped / staked / gold blocklist (USDT/USDC/WBTC/WETH/STETH/BETH/
# WBETH/CBETH/RETH/WSTETH/PAXG/XAUT/etc.). Add anything else you want to
# keep out (comma-separated bases, NO "/USDT" suffix).
DYNAMIC_EXCLUDE_BASES=PAXG,XAUT,BETH,STETH,OKSOL,WBTC,WETH

# ===================================================================
# V5.2 — OKX rate-limit protection (advanced)
# ===================================================================
# These tunables control how often market_data.py is allowed to hit OKX
# public endpoints. Defaults are conservative and tuned for free-tier
# public access. You usually do NOT need to change them.

# Bulk-tickers cache TTL. The price-watch loop and per-symbol ticker calls
# all read from this cache. Higher = fewer requests; lower = fresher prices.
OKX_TICKER_BULK_TTL_SECONDS=2

# Candle cache TTL for short (1m/3m/5m/15m/30m) vs long (1h/4h/1d).
OKX_CANDLE_TTL_SHORT_SECONDS=45
OKX_CANDLE_TTL_LONG_SECONDS=240

# Global cooldown after OKX returns HTTP 429 (or code 50011). The market
# layer pauses outbound requests for this many seconds.
OKX_RATE_LIMIT_COOLDOWN_SECONDS=20

# Per-symbol cooldown applied when a single instrument fails (429 OR error).
# Prevents one broken symbol from eating the whole rate-limit budget.
OKX_PER_SYMBOL_COOLDOWN_SECONDS=60

# Minimum candle count per timeframe before a symbol is considered "clean"
# for trading. Symbols below this are tagged as skipped but do not block
# clean symbols.
OKX_CANDLE_REQUIRED_BARS=60

# Max concurrent in-flight candle fetches.
# V7 default lowered 4 → 3 to give larger MAX_SCAN_SYMBOLS room without
# bursting OKX request quotas.
OKX_CANDLE_FETCH_CONCURRENCY=3

# Paper-only "learning sample" fallback. If the bot has no open positions,
# the daily cap is not hit, and a candidate's score is between the
# training threshold and this lower bound, allow a tiny exploratory entry
# clearly labelled "PAPER LEARNING SAMPLE — not live-ready signal".
# This NEVER runs in okx_demo or okx_live, regardless of gate status.
LEARNING_SAMPLE_ENABLED=true
LEARNING_SAMPLE_MIN_SCORE=0.30
LEARNING_SAMPLE_SIZE_PCT=30        # % of normal size — tiny
LEARNING_SAMPLE_MAX_PER_DAY=6

# ======================================================================
# V5.4 — Realistic Paper Mode (NO live execution path is added)
# ======================================================================
# Paper profile. "live_readiness" (default) is conservative and the only
# profile whose closed trades count toward the demo/live readiness gate.
# "learning" allows learning_sample fallbacks but those are explicitly
# excluded from the gate.
PAPER_PROFILE=live_readiness

# Capital realism. Cash reserve is enforced inside can_enter AND clamps
# open quantity in open_long, so paper cash can no longer drain to $0.
MIN_CASH_RESERVE_PCT=35
MAX_CAPITAL_IN_POSITIONS_PCT=50

# Frequency realism (seconds). live_readiness also clamps
# max_trades_per_day <= 12. learning halves both cooldowns.
GLOBAL_TRADE_COOLDOWN_SECONDS=600
PER_SYMBOL_COOLDOWN_SECONDS=2700

# Fill realism — market buy fills at ask*(1+slip), market sell at bid*(1-slip).
REALISTIC_FILLS_ENABLED=true

# Exit verification — the impossible TP/SL fix. A paper exit only triggers
# if live ticker bid/ask/last or the most recent candle high/low proves the
# trigger price was reachable. Refused exits emit an `exit_blocked` SSE
# event and the position stays open.
EXIT_VERIFICATION_ENABLED=true

# Symbol-adaptive intelligence (ATR/spread/volume → SL/TP/size multipliers).
SYMBOL_ADAPTIVE_ENABLED=true
SYMBOL_MIN_ATR_PCT=0.08
SYMBOL_MAX_ATR_PCT=6.0
SYMBOL_MAX_SPREAD_PCT=0.35
SYMBOL_MIN_QUOTE_VOL_USDT=1000000

# Stable/pegged/synthetic exclusion. Engine also blocks any base
# starting/ending with USD as a safety net regardless of this list.
PAPER_EXCLUDED_BASES=USDG,USDC,RLUSD,DAI,TUSD,FDUSD,PYUSD,BUSD,USDK,EURT,GUSD,USDD,USTC,PAXG,XAUT,BETH,STETH,OKSOL,WBTC,WETH

# ======================================================================
# V6 — Tiny OKX Live Tester (REAL MONEY — disabled by default)
# ======================================================================
# Master switch. The tester will not place a real order unless ALL of the
# following are true:
#   1) LIVE_TESTER_ENABLED=true
#   2) OKX_API_KEY / OKX_API_SECRET / OKX_API_PASSPHRASE are set and authed
#   3) EXECUTION_MODE=okx_live AND LIVE_TRADING_ENABLED=true
#   4) LIVE_TRADING_ACK=I_ACCEPT_REAL_MONEY_RISK
#   5) LIVE_DEMO_COMPLETED_ACK=I_RAN_OKX_DEMO_FIRST
#   6) Either the V5.4 readiness gate passes, OR
#      LIVE_TESTER_OVERRIDE=I_UNDERSTAND_THIS_IS_A_TINY_TEST
#
# Stops are BOT-MANAGED. No native OKX algo orders are placed. If this
# app stops, SL/TP/trailing-stop will NOT trigger.
#
# Spot only. No leverage, no margin, no perps, no withdrawals.
#
# V6.4 — the dashboard now labels every paper position, every live-tester
# position, every committee candidate and every opportunity card with a
# Direction badge. In this build that badge is ALWAYS `LONG` (OKX spot
# buy). Shorts would require a separate margin/perps adapter that is NOT
# present in this codebase; do not expect to see SHORT badges until such
# an adapter ships.
LIVE_TESTER_ENABLED=false

# Per-order USDT notional cap for the tester. Hard-clamped to [1, 25] in
# settings.py and re-clamped just before order submission.
LIVE_MAX_ORDER_USDT=5

# Daily realised-loss cap (USDT). When breached the kill switch engages
# automatically and blocks further entries until you release it from the UI.
LIVE_DAILY_LOSS_CAP_USDT=3

# Cap on the number of LIVE entries the tester may attempt per UTC day.
LIVE_MAX_TRADES_PER_DAY=3

# Block a second live entry into the same base symbol while one is open.
LIVE_ONE_POSITION_PER_SYMBOL=true

# Maximum simultaneously-open live tester positions.
LIVE_MAX_OPEN_POSITIONS=1

# Require the strategy to compute a stop-loss / take-profit / trailing-stop
# before submitting any live order. Strongly recommended.
LIVE_REQUIRE_PROTECTIVE_EXIT=true

# Disallow non-spot instruments. The tester also rejects any symbol that is
# not a SPOT product on OKX regardless of this flag.
#
# V6.4: keep this `true`. It is also the reason the UI labels everything
# LONG — the tester is physically incapable of placing a short on a
# spot product, and there is no margin/perps adapter wired.
LIVE_SPOT_ONLY=true

# Require free USDT >= (order_usdt * multiplier) so fees/slippage cannot
# overdraw the account on entry. Defaults to 1.10.
LIVE_FREE_RESERVE_MULTIPLIER=1.10

# OPTIONAL: explicit override to let the TINY TESTER run BEFORE the V5.4
# paper readiness gate passes. Useful only for the first tiny smoke trade.
# Set to the exact token below to take effect; any other value (including
# empty or mistyped) keeps the training gate blocking.
#
# IMPORTANT (V6.3): this override only affects the tiny live tester. The
# full okx_live strategy mode still independently requires the training
# gate to pass, plus LIVE_DEMO_COMPLETED_ACK + LIVE_TRADING_ACK +
# LIVE_TRADING_ENABLED. It is not a backdoor to full live execution.
#
# As of V6.3 the env-derived value is re-asserted after the persisted
# data/settings.json overlay, so a stale `false` from an earlier
# paper-only session can no longer suppress a freshly-set token.
# LIVE_TESTER_OVERRIDE=I_UNDERSTAND_THIS_IS_A_TINY_TEST
